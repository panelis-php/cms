{
    "name": "panelis-php/branch",
    "description": "Manage branches to organize data and enable multi-tenant access within the application",
    "keywords": ["panelis"],
    "type": "library",
    "autoload": {
        "psr-4": {
            "Panelis\\Branch\\": "src/",
            "Panelis\\Branch\\Database\\Factories\\": "database/factories/",
            "Panelis\\Branch\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panelis\\Branch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Panelis\\Branch\\Providers\\BranchServiceProvider"
            ]
        },
        "panelis": {
            "plugins": [
                "Panelis\\Branch\\Plugins\\BranchPlugin"
            ]
        }
    }
}
