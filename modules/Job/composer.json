{
    "name": "panelis-php/job",
    "description": "Monitor and manage queued jobs stored in the database",
    "keywords": ["panelis"],
    "type": "library",
    "autoload": {
        "psr-4": {
            "Panelis\\Job\\": "src/",
            "Panelis\\Job\\Database\\Factories\\": "database/factories/",
            "Panelis\\Job\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panelis\\Job\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Panelis\\Job\\Providers\\JobServiceProvider"
            ]
        },
        "panelis": {
            "plugins": [
                "Panelis\\Job\\Plugins\\JobPlugin"
            ]
        }
    }
}
