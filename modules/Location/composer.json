{
    "name": "panelis-php/location",
    "description": "Manage countries, regions, and cities used by the application",
    "keywords": ["panelis"],
    "type": "library",
    "autoload": {
        "psr-4": {
            "Panelis\\Location\\": "src/",
            "Panelis\\Location\\Database\\Factories\\": "database/factories/",
            "Panelis\\Location\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panelis\\Location\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Panelis\\Location\\Providers\\LocationServiceProvider"
            ]
        },
        "panelis": {
            "plugins": [
                "Panelis\\Location\\Plugins\\LocationPlugin"
            ]
        }
    }
}
