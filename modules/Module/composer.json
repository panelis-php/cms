{
    "name": "panelis-php/module",
    "description": "Manage application translations directly from the admin panel",
    "keywords": ["panelis"],
    "type": "library",
    "autoload": {
        "psr-4": {
            "Panelis\\Module\\": "src/",
            "Panelis\\Module\\Database\\Factories\\": "database/factories/",
            "Panelis\\Module\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panelis\\Module\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Panelis\\Module\\Providers\\ModuleServiceProvider"
            ]
        },
        "panelis": {
            "plugins": [
                "Panelis\\Module\\Plugins\\ModulePlugin"
            ]
        }
    }
}
