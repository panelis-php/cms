{
    "name": "panelis-php/setting",
    "description": "Manage application settings including general configuration, logging, mail, formatting, and system options",
    "keywords": ["panelis"],
    "autoload": {
        "psr-4": {
            "Panelis\\Setting\\": "src/",
            "Panelis\\Setting\\Database\\Factories\\": "database/factories/",
            "Panelis\\Setting\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panelis\\Setting\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Panelis\\Setting\\Providers\\SettingServiceProvider"
            ]
        },
        "panelis": {
            "plugins": [
                "Panelis\\Setting\\Plugins\\SettingPlugin"
            ]
        }
    }
}
