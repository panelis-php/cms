{
    "name": "panelis-php/user",
    "description": "Manage users, roles, and permissions for the application",
    "keywords": ["panelis"],
    "autoload": {
        "psr-4": {
            "Panelis\\User\\": "src/",
            "Panelis\\User\\Database\\Factories\\": "database/factories/",
            "Panelis\\User\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Panelis\\User\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Panelis\\User\\Providers\\UserServiceProvider"
            ]
        },
        "panelis": {
            "plugins": [
                "Panelis\\User\\Plugins\\UserPlugin"
            ]
        }
    }
}
